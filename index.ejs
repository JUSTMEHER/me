<!DOCTYPE html>
<html lang="en">
<%- include('./components/head') %>
<style>
.login-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-base);
    background-image:
        radial-gradient(ellipse 60% 50% at 50% 0%, rgba(56,182,255,0.07) 0%, transparent 70%);
    padding: 24px;
}
.login-card {
    width: 100%;
    max-width: 420px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 48px 40px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.6);
    text-align: center;
}
.login-logo {
    width: 72px;
    height: 72px;
    margin: 0 auto 24px;
    display: block;
}
.login-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    margin-bottom: 6px;
}
.login-sub {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 36px;
}
.login-divider {
    height: 1px;
    background: var(--border);
    margin: 28px 0;
}
.login-user-badge {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--bg-base);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 16px;
    text-align: left;
}
.login-user-badge img {
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 2px solid var(--accent-dim);
}
.login-user-name { font-size: 0.85rem; font-weight: 500; color: var(--text-primary); }
.login-user-sub  { font-size: 0.75rem; color: var(--text-muted); }
.login-btn-full  { width: 100%; justify-content: center; }
.login-switch {
    margin-top: 12px;
    font-size: 0.78rem;
    color: var(--text-muted);
}
.login-switch a { color: var(--accent); text-decoration: none; }
.login-switch a:hover { text-decoration: underline; }
</style>
<body>
<div class="login-page">
    <div class="login-card">
        <img src="/assets/mekudo-logo.png" class="login-logo" alt="<%= settings.name %>">
        <div class="login-title"><%= settings.name %></div>
        <div class="login-sub">Sign in with Discord to continue</div>

        <% if (!req.session.userinfo) { %>
            <a class="mk-btn login-btn-full" href="<%= extra.home.buttontext.loggedout.link %>"
               onclick="this.classList.add('loading'); this.style.opacity='0.7'">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.003.028.018.057.041.074a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
                </svg>
                Login with Discord
            </a>
        <% } else { %>
            <div class="login-user-badge">
                <img src="https://cdn.discordapp.com/avatars/<%= req.session.userinfo.id %>/<%= req.session.userinfo.avatar %>.png?size=64" alt="">
                <div>
                    <div class="login-user-name"><%= req.session.userinfo.username %></div>
                    <div class="login-user-sub">Signed in</div>
                </div>
            </div>
            <a class="mk-btn login-btn-full" href="<%= extra.home.buttontext.loggedin.link %>">
                Continue as <%= req.session.userinfo.username %>
            </a>
            <div class="login-switch">
                <a href="<%= extra.home.buttontext.loggedout.link %>">Sign in with a different account</a>
            </div>
        <% } %>
    </div>
</div>
<%- include('./components/scripts') %>
</body>
</html>
