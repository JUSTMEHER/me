    <style>
        :root {
            --bg-base:     #080c18;
            --bg-card:     #0d1220;
            --bg-sidebar:  #090d1b;
            --bg-nav:      #090d1b;
            --border:      #1a2540;
            --accent:      #38b6ff;
            --accent-dim:  #1a5a80;
            --accent-glow: rgba(56,182,255,0.15);
            --text-primary:#e2e8f0;
            --text-muted:  #4a6080;
            --text-sub:    #7a90b0;
            --success:     #22c55e;
            --danger:      #ef4444;
            --warning:     #f59e0b;
            --radius:      10px;
            --radius-lg:   16px;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Sora', sans-serif !important;
            background: var(--bg-base) !important;
            color: var(--text-primary) !important;
        }

        /* ── SCROLLBAR ── */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: var(--bg-base); }
        ::-webkit-scrollbar-thumb { background: var(--accent-dim); border-radius: 4px; }

        /* ── CARDS ── */
        .card {
            background: var(--bg-card) !important;
            border: 1px solid var(--border) !important;
            border-radius: var(--radius-lg) !important;
            box-shadow: 0 4px 24px rgba(0,0,0,0.4) !important;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            border-color: var(--accent-dim) !important;
            box-shadow: 0 4px 32px rgba(56,182,255,0.08) !important;
        }
        .card-body { padding: 24px !important; }

        /* ── PAGE TITLES ── */
        h2 {
            font-size: 1.5rem !important;
            font-weight: 600 !important;
            color: var(--text-primary) !important;
            letter-spacing: -0.02em;
            margin-bottom: 4px !important;
        }
        .text-gray, p.text-gray {
            color: var(--text-sub) !important;
            font-size: 0.85rem !important;
            margin-bottom: 24px !important;
        }

        /* ── PRIMARY BUTTON ── */
        .mk-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 24px;
            background: var(--accent);
            color: #000 !important;
            font-family: 'Sora', sans-serif;
            font-weight: 600;
            font-size: 0.85rem;
            border: none;
            border-radius: var(--radius);
            cursor: pointer;
            text-decoration: none !important;
            transition: opacity 0.15s, transform 0.15s;
            letter-spacing: 0.01em;
        }
        .mk-btn:hover { opacity: 0.88; transform: translateY(-1px); }
        .mk-btn:active { transform: translateY(0); }

        .mk-btn-danger {
            background: transparent;
            color: var(--danger) !important;
            border: 1px solid var(--danger);
        }
        .mk-btn-danger:hover { background: rgba(239,68,68,0.1); }

        .mk-btn-ghost {
            background: transparent;
            color: var(--accent) !important;
            border: 1px solid var(--border);
        }
        .mk-btn-ghost:hover { border-color: var(--accent); background: var(--accent-glow); }

        /* ── OLD BUTTON COMPAT ── */
        .button {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 28px;
            background: var(--accent);
            border: none;
            border-radius: var(--radius);
            cursor: pointer;
            text-decoration: none !important;
            transition: opacity 0.15s;
        }
        .button__text { color: #000; font-weight: 600; font-size: 0.85rem; transition: all 0.2s; }
        .button--loading .button__text { visibility: hidden; opacity: 0; }
        .button--loading::after {
            content: "";
            position: absolute;
            width: 18px; height: 18px;
            top: 0; left: 0; right: 0; bottom: 0;
            margin: auto;
            border: 2px solid transparent;
            border-top-color: #000;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        .button2 {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 80px; height: 80px;
            background: var(--bg-card);
            border: 2px dashed var(--border);
            border-radius: 50%;
            cursor: pointer;
            text-decoration: none !important;
            transition: border-color 0.2s, background 0.2s;
        }
        .button2:hover { border-color: var(--accent); background: var(--accent-glow); }
        .button2__text { color: var(--accent); font-size: 2rem; font-weight: 300; transition: all 0.2s; }
        .button2--loading .button2__text { visibility: hidden; opacity: 0; }
        .button2--loading::after {
            content: "";
            position: absolute;
            width: 32px; height: 32px;
            top: 0; left: 0; right: 0; bottom: 0;
            margin: auto;
            border: 3px solid transparent;
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin { to { transform: rotate(1turn); } }

        /* ── ALERTS ── */
        .alert {
            padding: 12px 16px !important;
            border-radius: var(--radius) !important;
            background: rgba(56,182,255,0.1) !important;
            border: 1px solid var(--accent-dim) !important;
            color: var(--accent) !important;
            font-size: 0.85rem !important;
            margin-bottom: 16px !important;
        }

        /* ── FORM CONTROLS ── */
        .form-control, select.form-control {
            background: var(--bg-base) !important;
            border: 1px solid var(--border) !important;
            border-radius: var(--radius) !important;
            color: var(--text-primary) !important;
            font-family: 'Sora', sans-serif !important;
            font-size: 0.85rem !important;
            padding: 10px 14px !important;
            transition: border-color 0.15s !important;
        }
        .form-control:focus, select.form-control:focus {
            border-color: var(--accent) !important;
            box-shadow: 0 0 0 3px var(--accent-glow) !important;
            outline: none !important;
        }
        label { color: var(--text-sub) !important; font-size: 0.8rem !important; font-weight: 500 !important; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 8px !important; }

        /* ── STAT BADGE ── */
        .mk-stat {
            display: flex;
            flex-direction: column;
            gap: 4px;
            padding: 16px 20px;
            background: var(--bg-base);
            border: 1px solid var(--border);
            border-radius: var(--radius);
        }
        .mk-stat-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); }
        .mk-stat-value { font-size: 1.4rem; font-weight: 600; color: var(--text-primary); }
        .mk-stat-accent { color: var(--accent); }

        /* ── PAGE HEADER ── */
        .mk-page-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 28px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border);
        }

        /* ── CONTENT WRAPPER ── */
        .content-wrapper {
            background: var(--bg-base) !important;
            padding: 32px !important;
        }
        .main-panel, .page-body-wrapper, .container-scroller {
            background: var(--bg-base) !important;
        }

        /* ── BTN COMPAT ── */
        .btn-primary {
            background: var(--accent) !important;
            border-color: var(--accent) !important;
            color: #000 !important;
            font-weight: 600 !important;
            border-radius: var(--radius) !important;
        }
        .btn-danger {
            background: transparent !important;
            border: 1px solid var(--danger) !important;
            color: var(--danger) !important;
            font-weight: 600 !important;
            border-radius: var(--radius) !important;
        }
        .btn-danger:hover { background: rgba(239,68,68,0.1) !important; }
        .btn-warning {
            background: transparent !important;
            border: 1px solid var(--warning) !important;
            color: var(--warning) !important;
            font-weight: 600 !important;
            border-radius: var(--radius) !important;
        }

        /* ── NANOBAR ── */
        .nanobar .bar { background: var(--accent) !important; height: 2px !important; }
    </style>
</head>
<body>
<div class="nanobar my-class" id="my-id" style="position:fixed;"><div class="bar"></div></div>
