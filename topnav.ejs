<style>
.navbar {
    background: var(--bg-nav) !important;
    border-bottom: 1px solid var(--border) !important;
    height: 60px !important;
    padding: 0 24px !important;
}
.navbar-brand-wrapper {
    background: var(--bg-nav) !important;
    border-bottom: 1px solid var(--border) !important;
}
.navbar-brand { color: var(--text-primary) !important; font-weight: 700 !important; }
.navbar-menu-wrapper { background: transparent !important; }
.navbar-toggler { color: var(--text-sub) !important; border: none !important; }
.navbar-toggler .mdi { color: var(--text-sub) !important; font-size: 1.2rem; }

/* Profile dropdown */
.navbar-profile { display: flex; align-items: center; gap: 10px; cursor: pointer; }
.navbar-profile img {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 2px solid var(--border);
}
.navbar-profile-name {
    font-size: 0.82rem !important;
    font-weight: 500 !important;
    color: var(--text-primary) !important;
}
.mdi-menu-down { color: var(--text-muted) !important; }

/* Dropdown */
.dropdown-menu {
    background: var(--bg-card) !important;
    border: 1px solid var(--border) !important;
    border-radius: var(--radius-lg) !important;
    padding: 8px !important;
    min-width: 200px !important;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5) !important;
}
.dropdown-item {
    border-radius: var(--radius) !important;
    color: var(--text-sub) !important;
    font-size: 0.82rem !important;
    padding: 10px 12px !important;
    transition: background 0.15s, color 0.15s !important;
}
.dropdown-item:hover {
    background: var(--accent-glow) !important;
    color: var(--accent) !important;
}
.dropdown-divider { border-color: var(--border) !important; margin: 4px 0 !important; }
.preview-subject { color: var(--text-sub) !important; font-size: 0.82rem !important; margin: 0 !important; }

/* Coin badge in nav */
.mk-coin-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    background: var(--accent-glow);
    border: 1px solid var(--accent-dim);
    border-radius: 99px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
    margin-right: 8px;
}
</style>

<nav class="navbar p-0 fixed-top d-flex flex-row">
    <div class="navbar-brand-wrapper d-flex d-lg-none align-items-center justify-content-center">
        <a class="navbar-brand brand-logo-mini" href="../dashboard"><%= settings.letter %></a>
    </div>
    <div class="navbar-menu-wrapper flex-grow d-flex align-items-stretch">
        <button class="navbar-toggler align-self-center" type="button" data-toggle="minimize">
            <span class="mdi mdi-menu"></span>
        </button>
        <ul class="navbar-nav navbar-nav-right align-items-center">
            <li class="nav-item d-none d-sm-flex">
                <span class="mk-coin-badge">
                    🪙 <span id="balance"></span>
                </span>
            </li>
            <li class="nav-item dropdown">
                <a class="nav-link" id="profileDropdown" href="#" data-toggle="dropdown">
                    <div class="navbar-profile">
                        <img src="https://cdn.discordapp.com/avatars/<%= userinfo.id %>/<%= userinfo.avatar %>.png?size=256" alt="">
                        <p class="mb-0 d-none d-sm-block navbar-profile-name"><%= userinfo.username %></p>
                        <i class="mdi mdi-menu-down d-none d-sm-block"></i>
                    </div>
                </a>
                <div class="dropdown-menu dropdown-menu-right navbar-dropdown" aria-labelledby="profileDropdown">
                    <a class="dropdown-item" href="/afk">
                        <p class="preview-subject">🪙 Coins: <strong style="color:var(--accent)" id="balance2"></strong></p>
                    </a>
                    <a class="dropdown-item" href="/dashboard">
                        <p class="preview-subject">📋 Plan:
                            <% if (typeof packagename.charAt(0) == 'number') { %>
                                <%= packagename %>
                            <% } else { %>
                                <%= packagename.charAt(0).toUpperCase() + packagename.slice(1) %>
                            <% } %>
                        </p>
                    </a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item" href="/settings">Account Settings</a>
                    <a class="dropdown-item" href="/logout" style="color:var(--danger) !important">Logout</a>
                </div>
            </li>
        </ul>
        <button class="navbar-toggler navbar-toggler-right d-lg-none align-self-center" type="button" data-toggle="offcanvas">
            <span class="mdi mdi-format-line-spacing"></span>
        </button>
    </div>
</nav>
<script>
    const _coins = Math.floor(<%= coins %> * 100) / 100;
    document.getElementById("balance") && (document.getElementById("balance").textContent = _coins);
    document.getElementById("balance2") && (document.getElementById("balance2").textContent = _coins);
</script>
